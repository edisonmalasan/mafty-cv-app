{
  "compilerOptions": {
    /* Core */
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",

    /* Paths */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Node */
    "types": ["node"],

    /* Interop */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* Strictness */
    "strict": true,
    "skipLibCheck": true,

    /* DX */
    "sourceMap": true
  },
  "include": ["src", "index.ts"],
  "exclude": ["node_modules", "dist"]
}
