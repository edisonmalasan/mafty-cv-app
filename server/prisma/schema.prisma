
generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}


// USER
model User {
    id              String @id @default(uuid())
    email           String @unique
    passwordHash    String?
    name            String? 
    avatarUrl       String?
    provider        AuthProvider?
    providerId      String?
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt
}

enum AuthProvider {
    GOOGLE
    GITHUB
    LOCAL
}


// RESUME
model Resume {
    id          String @id @default(uuid())
    userId      String
    user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    title       String
    slug        String @unique
    isPublic    Boolean @default(false)
    templateId  String?
    template    Template? @relation(fields: [templateId], references: [id])
    header      ResumeHeader?
    sections    ResumeSection[]
    settings    ResumeSettings?
    exports     Export[]
    links       ResumeLink[]
    views       ResumeView[]
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}


// HEADER
model ResumeHeader {
    id          String @id @default(uuid())
    resumeId    String @unique
    resume      Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
    fullName    String?
    jobTitle    String?
    email       String?
    phone       String?
    website     String?
    address     String?
    linkedin    String?
    github      String? 
    avatarUrl   String?
    summary     String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

// RESUME SECTIONS
model ResumeSection {
    id         String @id @default(uuid())
    resumeId   String
    resume     Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
    type       SectionType
    title      String?
    position   Int
    visible    Boolean @default(true)
    // typed items
    experienceItems ExperienceItem[]
    educationItems  EducationItem[]
    projectItems    ProjectItem[]
    skillItems      SkillItem[]
    certificationItems CertificationItem[]
    languageItems   LanguageItem[]
    interestItems   InterestItem[]
    referenceItems  ReferenceItem[]
    organizationItems OrganizationItem[]
    publicationsItems PublicationItem[]
    awardItems AwardItem[]
    courseItems CourseItem[]
    customItems CustomItem[]
    createdAt  DateTime @default(now())
}

enum SectionType {
    EXPERIENCE
    EDUCATION
    PROJECTS
    SKILLS
    CERTIFICATIONS
    LANGUAGES
    INTERESTS
    REFERENCES
    ORGANIZATIONS
    PUBLICATIONS
    AWARDS
    COURSES
    CUSTOM
}


// EXPERIENCE ITEMS
model ExperienceItem {
    id          String @id @default(uuid())
    sectionId   String
    section     ResumeSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
    jobTitle    String?
    company     String?
    companyUrl  String?
    startDate   String?
    endDate     String?
    current     Boolean @default(false)
    location    String?
    description String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}


// EDUCATION ITEMS
model EducationItem {
    id          String @id @default(uuid())
    sectionId   String
    section     ResumeSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
    degree      String?
    school      String?
    schoolUrl   String?
    startDate   String?
    endDate     String?
    location    String?
    description String?
    position    Int
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}


// PROJECT ITEMS
model ProjectItem {
    id          String @id @default(uuid())
    sectionId   String
    section     ResumeSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
    name        String?
    role        String?
    url         String?
    startDate   String?
    endDate     String?
    description String?
    position    Int
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}


// SKILL ITEMS
model SkillItem {
    id          String @id @default(uuid())
    sectionId   String
    section     ResumeSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
    name        String?
    category    String?
    level       SkillLevel?
    position    Int
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

enum SkillLevel {
    BEGINNER
    INTERMEDIATE
    ADVANCED
    EXPERT
}

// CERTIFICATION ITEMS
model CertificationItem {
    id          String @id @default(uuid())
    sectionId   String
    section     ResumeSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
    name        String?
    issuerUrl   String?
    issueDate   String?
    credentialId String?
    description String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

// LANGUAGE ITEMS
model LanguageItem {
  id          String        @id @default(uuid())
  sectionId   String
  section     ResumeSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  language    String?
  proficiency Proficiency?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum Proficiency {
    BASIC
    CONVERSATIONAL
    PROFICIENT
    FLUENT
    NATIVE
}

// INTEREST ITEMS
model InterestItem {
  id        String        @id @default(uuid())
  sectionId String
  section   ResumeSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  name      String?
  interest  String?
  interestUrl String?
  description String?
  position  Int
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}


// REFERENCE ITEMS
model ReferenceItem {
  id           String     @id @default(uuid())
  sectionId    String
  section      ResumeSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  name         String?
  nameUrl      String?
  jobTitle     String?       
  organization String?
  email        String?
  phone        String?
  description  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// ORGANIZATION ITEMS
model OrganizationItem {
  id          String     @id @default(uuid())
  sectionId   String
  section     ResumeSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  organization String?
  organizationUrl         String?
  position       String?
  startDate   String?
  endDate     String?
  location    String?
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// PUBLICATION ITEMS
model PublicationItem {
  id          String        @id @default(uuid())
  sectionId   String
  section     ResumeSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title       String?
  titleUrl    String?
  publisher   String?
  date        DateTime?
  description String?
  position    Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// AWARD ITEMS
model AwardItem {
  id          String        @id @default(uuid())
  sectionId   String
  section     ResumeSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  award       String?
  awardUrl    String?
  issuer      String?
  date        DateTime?
  description String?
  position    Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}